<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <script src="https://cdn.tailwindcss.com"></script>

    <title>Premium Login & Signup</title>
  </head>

  <body class="bg-gray-100 min-h-screen flex items-center justify-center p-4">
    <div
      class="w-full max-w-5xl bg-white rounded-3xl shadow-2xl overflow-hidden flex flex-col md:flex-row">
      <!-- Left Section -->
      <div
        class="md:w-1/2 bg-red-600 text-white p-10 flex flex-col justify-center">
        <h1 class="text-5xl font-bold mb-4">LuxeCarry</h1>

        <p class="text-lg opacity-90 leading-relaxed">
          Discover premium bags crafted with elegance, style, and comfort for
          every occasion.
        </p>

        <div class="mt-10">
          <img
            src="https://images.unsplash.com/photo-1584917865442-de89df76afd3?w=800"
            alt="Bag"
            class="rounded-2xl shadow-lg object-cover h-72 w-full" />
        </div>
      </div>

      <!-- Right Section -->
      <div class="md:w-1/2 p-10">
        <!-- Toggle Buttons -->
        <div class="flex bg-gray-100 rounded-xl p-1 mb-8">
          <button
            onclick="showLogin()"
            id="loginBtn"
            class="w-1/2 py-3 rounded-lg bg-red-600 text-white font-semibold transition">
            Login
          </button>

          <button
            onclick="showSignup()"
            id="signupBtn"
            class="w-1/2 py-3 rounded-lg text-gray-700 font-semibold transition">
            Signup
          </button>
        </div>

        <!-- LOGIN FORM -->
        <form id="loginForm" action="" method="post">
          <h2 class="text-3xl font-bold text-gray-800 mb-2">Welcome Back</h2>

          <p class="text-gray-500 mb-6">Login to your account</p>

          <input
            type="email"
            name="email"
            placeholder="Email Address"
            class="w-full p-3 border-2 border-gray-200 rounded-xl mb-4 outline-none focus:border-red-500 transition" />

          <input
            type="password"
            name="password"
            placeholder="Password"
            class="w-full p-3 border-2 border-gray-200 rounded-xl mb-3 outline-none focus:border-red-500 transition" />

          <div class="text-right mb-5">
            <a href="#" class="text-red-600 hover:underline text-sm">
              Forgot Password?
            </a>
          </div>

          <button
            class="w-full bg-red-600 text-white py-3 rounded-xl font-semibold hover:bg-red-700 transition">
            Login
          </button>
        </form>

        <!-- SIGNUP FORM -->
        <form id="signupForm" class="hidden" action="" method="post">
          <h2 class="text-3xl font-bold text-gray-800 mb-2">Create Account</h2>

          <p class="text-gray-500 mb-6">Join our premium collection</p>

          <input
            type="text"
            placeholder="Full Name"
            class="w-full p-3 border-2 border-gray-200 rounded-xl mb-4 outline-none focus:border-red-500 transition"
            name="fullName" />

          <input
            type="email"
            placeholder="Email Address"
            class="w-full p-3 border-2 border-gray-200 rounded-xl mb-4 outline-none focus:border-red-500 transition"
            name="email" />

          <input
            type="password"
            placeholder="Password"
            class="w-full p-3 border-2 border-gray-200 rounded-xl mb-5 outline-none focus:border-red-500 transition"
            name="password" />

          <button
            class="w-full bg-red-600 text-white py-3 rounded-xl font-semibold hover:bg-red-700 transition">
            Signup
          </button>
        </form>
      </div>
    </div>

    <script>
      const loginForm = document.getElementById("loginForm");
      const signupForm = document.getElementById("signupForm");

      const loginBtn = document.getElementById("loginBtn");
      const signupBtn = document.getElementById("signupBtn");

      function showLogin() {
        loginForm.classList.remove("hidden");
        signupForm.classList.add("hidden");

        loginBtn.classList.add("bg-red-600", "text-white");
        signupBtn.classList.remove("bg-red-600", "text-white");
        signupBtn.classList.add("text-gray-700");
      }

      function showSignup() {
        signupForm.classList.remove("hidden");
        loginForm.classList.add("hidden");

        signupBtn.classList.add("bg-red-600", "text-white");
        loginBtn.classList.remove("bg-red-600", "text-white");
        loginBtn.classList.add("text-gray-700");
      }
    </script>
  </body>
</html>
